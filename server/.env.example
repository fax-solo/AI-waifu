# Gemini API Key (get free at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Server Port
PORT=3001

# Encryption secret for user API keys (generate a random 32-char string)
ENCRYPTION_SECRET=change-this-to-a-random-32-char-string

# Daily message limit per user (free tier optimization)
DAILY_MESSAGE_LIMIT=50

# Cooldown between messages in milliseconds (2 seconds)
MESSAGE_COOLDOWN_MS=2000
