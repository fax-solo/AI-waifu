{
  "name": "waifu-ai-companion",
  "version": "1.0.3",
  "private": true,
  "description": "AI Companion Chat powered by Gemini",
  "author": "User",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "npx -y concurrently -n server,client,electron -c blue,magenta,green \"npm run dev:server\" \"npm run dev:client\" \"npm run dev:electron\"",
    "dev:server": "cd server && node src/index.js",
    "dev:client": "cd client && npm run dev",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build:client": "cd client && node build.mjs",
    "build:desktop": "npm run download:models && npm run build:client && electron-builder build --win",
    "publish:desktop": "npm run download:models && npm run build:client && electron-builder publish --win --publish always",
    "download:models": "node download-models.mjs",
    "install:all": "cd server && npm install && cd ../client && npm install && npm install",
    "start": "electron ."
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "electron-is-dev": "^3.0.1",
    "electron-updater": "^6.8.3",
    "express": "^4.21.2",
    "sql.js": "^1.12.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^10.1.0",
    "electron": "^34.5.8",
    "electron-builder": "^26.8.1",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.waifu.ai",
    "productName": "WaifuAI",
    "electronVersion": "34.5.8",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "client/dist/**/*",
      "server/package.json",
      "server/src/**/*",
      "server/node_modules/**/*",
      "!server/data/waifu.db",
      "server/data/animations/**/*",
      "server/data/gallery/**/*",
      "electron/**/*",
      "python/*.py",
      "!python/*.onnx",
      "!python/*.bin",
      "!python/venv/**/*",
      "!python/venv2/**/*",
      "!python/tts_cache/**/*",
      "package.json",
      "models.json",
      "get-pip.py",
      "electron/preload.cjs"
    ],
    "publish": {
      "provider": "github",
      "owner": "fax-solo",
      "repo": "AI-waifu"
    },
    "removePackageScripts": true,
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "client/public/icon.ico",
      "verifyUpdateCodeSignature": false,
      "compression": "maximum"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "WaifuAI Companion",
      "artifactName": "WaifuAI-Setup-${version}.exe",
      "uninstallDisplayName": "WaifuAI Companion",
      "deleteAppDataOnUninstall": false
    },
    "extraMetadata": {
      "main": "electron/main.js"
    }
  },
  "overrides": {}
}
