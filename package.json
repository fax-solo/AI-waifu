{
  "name": "waifu-ai-companion",
  "version": "1.0.0",
  "private": true,
  "description": "AI Companion Chat powered by Gemini",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "npx -y concurrently -n server,client,electron -c blue,magenta,green \"npm run dev:server\" \"npm run dev:client\" \"npm run dev:electron\"",
    "dev:server": "cd server && node src/index.js",
    "dev:client": "cd client && npx vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build:client": "cd client && npm run build",
    "build:desktop": "npm run build:client && electron-builder build --win",
    "install:all": "cd server && npm install && cd ../client && npm install && npm install",
    "start": "electron ."
  },
  "dependencies": {
    "electron-is-dev": "^3.0.1",
    "@google/generative-ai": "^0.24.0",
    "sql.js": "^1.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "electron": "^34.3.0",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.waifu.ai",
    "productName": "Waifu AI Companion",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "client/dist/**/*",
      "server/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "portable",
      "icon": "client/public/vite.svg"
    },
    "extraMetadata": {
      "main": "electron/main.js"
    }
  }
}
